{{- $index := slice -}}
{{- range where .Site.RegularPages "Kind" "page" -}}

{{- $content := delimit (slice
  .Title
  (.Content | plainify | htmlUnescape)
  (.Params.description | default "")
  (.Params.tags | delimit " ")
  (.Params.categories | delimit " ")
) " " -}}

{{- $index = $index | append (dict 
  "title" .Title 
  "content" $content
  "link" .RelPermalink 
  "imagePoster" (or .Params.imagePoster "/default.png")
) -}}

{{- end -}}
{{ $index | jsonify }}