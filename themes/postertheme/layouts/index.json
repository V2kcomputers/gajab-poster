{{- $index := slice -}}
{{- range .Site.RegularPages -}}

{{- $about := delimit (.Params.aboutPost | default (slice)) " " -}}
{{- $highlights := delimit (.Params.KeyHighlights | default (slice)) " " -}}
{{- $important := delimit (.Params.ImportantDetails | default (slice)) " " -}}
{{- $tags := delimit (.Params.tags | default (slice)) " " -}}
{{- $cats := delimit (.Params.categories | default (slice)) " " -}}

{{- $hindiShort := delimit (.Params.Short_Hindi_Sharing | default (slice)) " " -}}
{{- $hindiFull := delimit (.Params.Hindi_Sharing | default (slice)) " " -}}

{{- $content := delimit (slice
  .Title
  (.Params.Headline | default "")
  (.Params.Subheading | default "")
  (.Params.Description | default "")
  (.Params.Footer_Info | default "")
  $about
  $highlights
  $important
  $tags
  $cats
  $hindiShort
  $hindiFull
) " " -}}

{{- $index = $index | append (dict 
  "title" .Title 
  "content" $content
  "link" .RelPermalink 
  "imagePoster" (or .Params.imagePoster "/default.png")
) -}}

{{- end -}}
{{ $index | jsonify }}